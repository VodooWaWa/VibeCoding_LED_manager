{
  "hooks": {
    "SessionStart": [
      {"hooks": [
        {"type": "command", "command": "python \"<PROJECT_DIR>/transport/send.py\" off --platform reasonix", "timeout": 5}
      ]}
    ],
    "UserPromptSubmit": [
      {"hooks": [
        {"type": "command", "command": "python \"<PROJECT_DIR>/transport/send.py\" thinking --platform reasonix", "timeout": 5}
      ]}
    ],
    "PreToolUse": [
      {"hooks": [
        {"type": "command", "command": "python \"<PROJECT_DIR>/transport/send.py\" busy --platform reasonix", "timeout": 5}
      ]}
    ],
    "PostToolUse": [
      {"hooks": [
        {"type": "command", "command": "python \"<PROJECT_DIR>/transport/send.py\" thinking --platform reasonix", "timeout": 5}
      ]}
    ],
    "PermissionRequest": [
      {"hooks": [
        {"type": "command", "command": "python \"<PROJECT_DIR>/transport/send.py\" waiting --platform reasonix", "timeout": 5}
      ]}
    ],
    "PostLLMCall": [
      {"hooks": [
        {"type": "command", "command": "python \"<PROJECT_DIR>/transport/send.py\" thinking --platform reasonix", "timeout": 5}
      ]}
    ],
    "Stop": [
      {"hooks": [
        {"type": "command", "command": "python \"<PROJECT_DIR>/transport/send.py\" success --platform reasonix", "timeout": 5}
      ]}
    ],
    "SubagentStop": [
      {"hooks": [
        {"type": "command", "command": "python \"<PROJECT_DIR>/transport/send.py\" off --platform reasonix", "timeout": 5}
      ]}
    ],
    "PreCompact": [
      {"hooks": [
        {"type": "command", "command": "python \"<PROJECT_DIR>/transport/send.py\" busy --platform reasonix", "timeout": 5}
      ]}
    ],
    "SessionEnd": [
      {"hooks": [
        {"type": "command", "command": "python \"<PROJECT_DIR>/transport/send.py\" off --platform reasonix", "timeout": 5}
      ]}
    ]
  }
}
